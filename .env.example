DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
PORT=3001
FRONTEND_URL="http://localhost:3000"

PSU_CLIENT_ID="your-psu-client-id"
PSU_CLIENT_SECRET="your-psu-client-secret"
PSU_OPENID_URL="https://example.com/.well-known/openid-configuration"
# This is the OAuth redirect_uri that Better Auth sends to PSU.
# It MUST match what is registered in the PSU OAuth app dashboard.
PSU_CALLBACK_URL="http://localhost:3001/api/auth/callback/psu"
FALLBACK_FACULTY_ID="00000000-0000-0000-0000-000000000000"
ALLOW_DEV_ROLE_SWITCHING="false"

# Better Auth (OAuth/OIDC client for PSU Passport)
BETTER_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET="replace-with-a-random-secret"

JWT_SECRET="replace-with-a-random-secret"
COOKIE_SECRET="replace-with-a-random-secret"
